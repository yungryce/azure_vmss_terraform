*.coverage
*.coveragexml
*.testResults
.env.local
# GitHub Actions
.github/workflows/*.secrets

# --- Ignore Generated Files ---
# Helm Charts
charts/
# Terraform Plan Outputs
*.tfplan
# Auto-generated Kubernetes manifests
*.generated.yaml
*.generated.yml

